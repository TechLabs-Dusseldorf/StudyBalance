    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@tanstack/react-query": "^5.90.20",
    "axios": "^1.13.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.13.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^2.8.1",
    "@eslint/js": "^9.39.2",
